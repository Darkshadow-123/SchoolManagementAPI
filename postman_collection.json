{
  "info": {
    "name": "School Management API",
    "description": "Collection for School Management APIs - Add and List Schools",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Add School",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{baseUrl}}/addSchool",
          "host": ["{{baseUrl}}"],
          "path": ["addSchool"]
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"Springfield High School\",\n    \"address\": \"123 Main Street, Springfield\",\n    \"latitude\": 40.7128,\n    \"longitude\": -74.0060\n}"
        },
        "description": "Add a new school to the database"
      },
      "response": []
    },
    {
      "name": "List Schools (Sorted by Proximity)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/listSchools?latitude=40.7128&longitude=-74.0060",
          "host": ["{{baseUrl}}"],
          "path": ["listSchools"],
          "query": [
            {
              "key": "latitude",
              "value": "40.7128"
            },
            {
              "key": "longitude",
              "value": "-74.0060"
            }
          ]
        },
        "description": "Get all schools sorted by distance from user location"
      },
      "response": []
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        },
        "description": "Check if the API is running"
      },
      "response": []
    }
  ]
}
